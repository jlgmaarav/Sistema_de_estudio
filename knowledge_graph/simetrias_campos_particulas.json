    { "id": "sc.3.04", "tema": 3, "nombre": "Zitterbewegung", "descripcion": "Interferencia de energías positivas y negativas, movimiento tembloroso.", "prerequisitos": [{ "id": "sc.3.03", "peso": 1.0 }], "fuentes": { "guia": "Bloque 3" } },
    { "id": "sc.3.05", "tema": 3, "nombre": "Mar de Dirac y antipartículas", "descripcion": "Interpretación de las energías negativas, predicción del positrón.", "prerequisitos": [{ "id": "sc.3.03", "peso": 1.0 }], "fuentes": { "guia": "Bloque 3" } },
    { "id": "sc.3.06", "tema": 3, "nombre": "Dirac con campo EM: momento magnético", "descripcion": "Acoplamiento mínimo, límite no relativista (Pauli), factor g=2.", "prerequisitos": [{ "id": "sc.3.03", "peso": 1.0 }, { "id": "mc.4.04", "peso": 1.0 }], "fuentes": { "guia": "Bloque 3" } },
