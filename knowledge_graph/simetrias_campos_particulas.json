    { "id": "sc.4.03", "tema": 4, "nombre": "Conexión con la física de partículas", "descripcion": "Campos y partículas del modelo estándar como representaciones de simetrías.", "prerequisitos": [{ "id": "sc.4.02", "peso": 1.0 }, { "id": "np.2.05", "peso": 0.5 }], "fuentes": { "guia": "Bloque 4" } }
