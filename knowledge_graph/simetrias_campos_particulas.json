    { "id": "sc.1.07", "tema": 1, "nombre": "Teorema de Noether para campos", "descripcion": "Simetrías continuas y corrientes conservadas; tensor energía-momento canónico.", "prerequisitos": [{ "id": "sc.1.02", "peso": 1.0 }, { "id": "sc.1.04", "peso": 1.0 }], "fuentes": { "guia": "Bloque 1" } },
