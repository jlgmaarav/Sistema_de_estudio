    { "id": "sc.2.02", "tema": 2, "nombre": "KG: soluciones libres", "descripcion": "Soluciones de partícula libre, espacio de momentos, energías negativas.", "prerequisitos": [{ "id": "sc.2.01", "peso": 1.0 }], "fuentes": { "guia": "Bloque 2" } },
    { "id": "sc.2.03", "tema": 2, "nombre": "KG: problemas de interpretación", "descripcion": "Densidad no definida positiva, límites como ecuación de una partícula.", "prerequisitos": [{ "id": "sc.2.02", "peso": 1.0 }], "fuentes": { "guia": "Bloque 2" } },
