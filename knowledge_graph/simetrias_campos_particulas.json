  "nodos": [
    { "id": "sc.1.01", "tema": 1, "nombre": "De sistemas discretos a continuos", "descripcion": "Paso al continuo, densidad lagrangiana, el campo como sistema dinámico.", "prerequisitos": [{ "id": "mt.04", "peso": 1.0 }], "fuentes": { "guia": "Bloque 1" } },
    { "id": "sc.1.02", "tema": 1, "nombre": "Euler-Lagrange para campos", "descripcion": "Ecuaciones de campo desde un principio variacional; ejemplos (cuerda, campo escalar).", "prerequisitos": [{ "id": "sc.1.01", "peso": 1.0 }], "fuentes": { "guia": "Bloque 1" } },
