    { "id": "sc.4.01", "tema": 4, "nombre": "Cuantización del campo electromagnético", "descripcion": "Modos del campo, osciladores, fotones.", "prerequisitos": [{ "id": "sc.1.08", "peso": 1.0 }, { "id": "mc.3.02", "peso": 1.0 }], "fuentes": { "guia": "Bloque 4" } },
