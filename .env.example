# Copia este archivo a .env y rellena tu clave
GEMINI_API_KEY=TU_CLAVE_AQUI
# gemini-3.5-flash = mejor modelo del free tier (recomendado).
# gemini-3.1-pro-preview = máxima calidad, pero requiere API de PAGO (billing activado);
#   la suscripción Pro de la app de Google NO da acceso a la API.
GEMINI_MODEL=gemini-3.5-flash
# Modelo de respaldo: si el principal falla (429/503/sin cuota), se reintenta con este.
# Debe ser un modelo DISTINTO y existente (tiene su propia cuota gratuita).
GEMINI_MODEL_FALLBACK=gemini-flash-lite-latest
TEMPERATURE=0.1
# Ruta absoluta a tu vault de Obsidian (por defecto: el directorio actual)
VAULT_PATH=
# El watcher, además del Inbox, puede escanear las carpetas Exámenes/Ejercicios de
# cada asignatura en "4º Física". Desactivado por defecto para NO duplicar los
# exámenes ya transcritos en el banco. Pon "true" para reactivarlo.
WATCHER_SCAN_SUBJECT_FOLDERS=false
